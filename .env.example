# Google AI Studio で取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here
# 任意: モデル名（省略時 gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash

# --- GitHub Actions → Netlify 自動デプロイ ---
# リポジトリ Settings → Secrets and variables → Actions で登録:
#   NETLIFY_AUTH_TOKEN  … Netlify User settings → Applications → Personal access tokens
#   NETLIFY_SITE_ID     … Netlify サイト → Site configuration → Site details → API ID
#   GEMINI_API_KEY      … playstyle 自動増殖用（任意。無くてもランキング更新は動く）
#
# ローカル手動実行:
#   python fetch_spla_log.py --auto --max-api 1
#   python fetch_spla_log.py --auto --min-rank 21 --max-api 4
